# Frontend (Vite) — same Client ID as Google Cloud OAuth Web client
# Add authorized JavaScript origins: http://localhost:5173
# Add authorized redirect URIs if needed. Use the same ID on server.
VITE_GOOGLE_CLIENT_ID=your-id.apps.googleusercontent.com

# Optional: API URL when frontend is hosted separately (leave empty when using same origin)
# VITE_API_URL=https://your-domain.com

# Server
PORT=3001
JWT_SECRET=generate-a-long-random-string
GOOGLE_CLIENT_ID=your-id.apps.googleusercontent.com
