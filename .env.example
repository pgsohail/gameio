# Frontend (Vite) — same Client ID as Google Cloud OAuth Web client
# Local: add http://localhost:5173 to Authorized JavaScript origins
# Production: add https://your-app.onrender.com
VITE_GOOGLE_CLIENT_ID=your-id.apps.googleusercontent.com

# Leave empty when UI and API share the same host (Render default)
# VITE_API_URL=https://your-app.onrender.com

# Server (required in production — Render auto-generates JWT_SECRET via render.yaml)
PORT=3001
NODE_ENV=production
JWT_SECRET=generate-a-long-random-string-min-32-chars
GOOGLE_CLIENT_ID=your-id.apps.googleusercontent.com
