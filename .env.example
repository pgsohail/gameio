# ── Google Sign-In (FREE — no credit card for basic OAuth) ──
# 1. https://console.cloud.google.com → create project "Buildup.io"
# 2. APIs & Services → OAuth consent screen → External → fill app name → Save
# 3. Credentials → Create credentials → OAuth client ID → Web application
# 4. Authorized JavaScript origins (add every host you deploy to):
#      http://localhost:5173
#      https://YOUR-APP.onrender.com
#      https://buildupio.fly.dev
# 5. Copy Client ID into both vars below (same value)

VITE_GOOGLE_CLIENT_ID=123456789-xxxx.apps.googleusercontent.com
GOOGLE_CLIENT_ID=123456789-xxxx.apps.googleusercontent.com

# Leave empty when UI and API share the same host (Render / Fly default)
# VITE_API_URL=

# Discord community invite (shown on home page)
# VITE_DISCORD_INVITE_URL=https://discord.gg/your-invite-code

PORT=3001
NODE_ENV=development
# Production (Fly/Render): use a long random string — openssl rand -hex 32
JWT_SECRET=local-dev-secret-change-me

# ── Fly.io deploy (free tier, no sleep) ──
# 1. fly auth login
# 2. ./scripts/fly-deploy.sh
# Or manually:
#    fly secrets set JWT_SECRET=... GOOGLE_CLIENT_ID=... -a buildupio
#    fly deploy --build-arg VITE_GOOGLE_CLIENT_ID=... -a buildupio
